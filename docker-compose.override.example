# Local-development Compose override template.
#
# Copy to docker-compose.override.yml when you need host access to the backend
# and source-built images instead of published Docker Hub images.
version: '3.8'

services:
  backend:
    build:
      context: ./zjus-backend
      dockerfile: Dockerfile
    # Required for local OpenAPI generation and browser/API smoke tests.
    ports:
      - "127.0.0.1:8000:8000"
    volumes:
      - ./zjus-backend/app:/app/app
      - ./zjus-backend/world:/app/world

  migrate:
    build:
      context: ./zjus-backend
      dockerfile: Dockerfile

  seed_embeddings:
    build:
      context: ./zjus-backend
      dockerfile: Dockerfile
    volumes:
      - ./zjus-backend/world:/app/world

  nginx:
    build:
      context: ./zjus-frontend
      dockerfile: Dockerfile
    ports:
      - "80:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/conf.d/local.conf:/etc/nginx/conf.d/default.conf:ro
      - ./zjus-backend/world:/usr/share/nginx/world
